{
  "rewrites": [
    {
      "source": "/",
      "destination": "/public/index.html"
    },
    {
      "source": "/draft",
      "destination": "/public/draft.html"
    },
    {
      "source": "/draft.html",
      "destination": "/public/draft.html"
    },
    {
      "source": "/app.js",
      "destination": "/public/app.js"
    },
    {
      "source": "/draft.js",
      "destination": "/public/draft.js"
    },
    {
      "source": "/styles.css",
      "destination": "/public/styles.css"
    },
    {
      "source": "/site.webmanifest",
      "destination": "/public/site.webmanifest"
    },
    {
      "source": "/icons/:path*",
      "destination": "/public/icons/:path*"
    }
  ]
}
